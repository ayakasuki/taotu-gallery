{
  "apps": [
    {
      "name": "taotu-gallery",
      "cwd": "/data1/桃图索引系统-alpha版本",
      "script": "server/index.js",
      "env": {
        "NODE_ENV": "production",
        "PORT": 7067
      },
      "instances": 1,
      "autorestart": true,
      "max_memory_restart": "512M",
      "log_date_format": "YYYY-MM-DD HH:mm:ss",
      "error_file": "./logs/pm2-error.log",
      "out_file": "./logs/pm2-out.log"
    }
  ]
}
