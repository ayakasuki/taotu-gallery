# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=gallery_index

# JWT 密钥
JWT_SECRET=change_this_to_a_random_string

# 服务端口（3000/3001 被占用，使用 3008）
PORT=3008

# 项目根目录（自动检测，通常不需要手动设置）
# PROJECT_ROOT=/data1/桃图索引系统-alpha版本

# Redis 配置（注册验证码/图片验证码使用；留空则验证码功能不可用）
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# 兼容小写写法
redis_host=
redis_port=6379
redis_username=
redis_password=
redis_db=0
