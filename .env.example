# 数据库配置
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# JWT 密钥
JWT_SECRET=

# 首次空库启动会自动创建首个管理员
# 不设置 DEFAULT_ADMIN_PASSWORD 时，系统会生成一次性随机密码并打印到启动日志
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_EMAIL=admin@example.com

# 服务端口（PM2 默认 7067，可按部署环境调整）
PORT=7067

# 项目根目录（自动检测，通常不需要手动设置）
# PROJECT_ROOT=/data1/桃图索引系统-alpha版本

# Redis 配置（图片验证码、注册邮箱验证码、忘记密码验证码使用）
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# 兼容小写写法
redis_host=
redis_port=6379
redis_username=
redis_password=
redis_db=0
